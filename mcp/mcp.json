{
	"mcpServers": {
		"mysql-k8s-pre": {
			"command": "uvx",
			"args": [
				"db-mcp-server"
			],
			"env": {
				"DB_TYPE": "mysql",
				"DB_MODE": "read-only",
				"DB_HOST": "10.198.3.38",
				"DB_PORT": "32606",
				"DB_USER": "root",
				"DB_PASSWORD": "123456",
				"DB_DATABASE": "acs_irconfdb",
				"SSH_HOST": "49.232.6.111",
				"SSH_PORT": "22",
				"SSH_USER": "root",
				"SSH_PASSWORD": "Fl#j27Br1U#uJ&S",
				"ALLOW_INSERT_OPERATION": "false",
				"ALLOW_UPDATE_OPERATION": "false",
				"ALLOW_DELETE_OPERATION": "false"
			}
		},
		"mongo-k8s-pre": {
			"command": "uvx",
			"args": [
				"db-mcp-server"
			],
			"env": {
				"DB_TYPE": "mongodb",
				"DB_MODE": "read-only",
				"DB_URL": "mongodb://127.0.0.1:27018/acsdb?directConnection=true",
				"DB_DATABASE": "acsdb"
			}
		},
		"gitlab": {
			"command": "npx",
			"args": [
				"-y",
				"gitlab-mcp"
			],
			"env": {
				"GITLAB_PERSONAL_ACCESS_TOKEN": "你的TOKEN",
				"GITLAB_TOKEN": "你的TOKEN",
				"GITLAB_URL": "https://gitcenter.aipark.com/api/v4"
			}
		},
		"mysql-local": {
			"command": "npx",
			"args": [
				"-y",
				"@benborla29/mcp-server-mysql"
			],
			"env": {
				"MYSQL_HOST": "127.0.0.1",
				"MYSQL_PORT": "3306",
				"MYSQL_USER": "root",
				"MYSQL_PASS": "123456",
				"MYSQL_DB": "jiayi_db",
				"ALLOW_INSERT_OPERATION": "true",
				"ALLOW_UPDATE_OPERATION": "true",
				"ALLOW_DELETE_OPERATION": "true"
			}
		},
		"playwright": {
			"command": "npx",
			"args": [
				"@playwright/mcp@latest",
				"--browser",
				"chrome",
				"--headless",
				"--viewport-size",
				"1920x1080",
				"--output-dir",
				"D:/tmp/playwright"
			]
		},
		"kubernetes-readonly": {
			"command": "uvx",
			"args": [
				"kubernetes-readonly-mcp@latest"
			]
		},
    "user-loki": {
      "command": "npx",
      "args": ["-y", "@elad12390/loki-mcp"],
      "env": {
        "LOKI_URL": "http://127.0.0.1:9999/"
      }
    }
	}
}